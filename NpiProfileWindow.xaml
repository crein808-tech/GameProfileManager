<Window x:Class="GameProfileManager.NpiProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="NVIDIA Profile Builder" Height="750" Width="650" MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterOwner" Background="#1E1E2E"
        ui:WindowHelper.UseModernWindowStyle="True">
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,6"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom" Background="#181825" Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Save .nip File" Style="{StaticResource AccentButtonStyle}"
                            Margin="0,0,8,0" Click="SaveNip_Click"/>
                    <Button Content="Open in NPI" Click="ApplyNow_Click"/>
                </StackPanel>
                <TextBlock x:Name="EditorStatus" Text="" Foreground="#6C7086" FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Top: game info -->
        <Border DockPanel.Dock="Top" Background="#181825" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Build a driver profile for:" Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,4"/>
                <TextBlock x:Name="GameNameText" Text="" Foreground="#CDD6F4" FontSize="16" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="NPI Profile Name:" Foreground="#A6ADC8" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="ProfileNameBox" MinWidth="300" FontSize="12"
                             ToolTip="Must match the profile name shown in NPI for this game"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Presets -->
        <Border DockPanel.Dock="Top" Background="#1E2030" Padding="16,10"
                BorderBrush="#45475A" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="PRESETS" Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,6"/>
                <StackPanel x:Name="PresetPanel"/>
            </StackPanel>
        </Border>

        <!-- Settings -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,8">
            <StackPanel x:Name="SettingsPanel" MaxWidth="580"/>
        </ScrollViewer>
    </DockPanel>
</Window>
