<Window x:Class="GameProfileManager.TweaksConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="DLSSTweaks Config Editor" Height="700" Width="620" MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner" Background="#1E1E2E"
        ui:WindowHelper.UseModernWindowStyle="True">
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,6"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#181825" Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Save Config" Style="{StaticResource AccentButtonStyle}"
                        Click="Save_Click"/>
                <TextBlock x:Name="EditorStatus" Text="" Foreground="#6C7086" FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,12">
            <StackPanel x:Name="SettingsPanel" MaxWidth="560"/>
        </ScrollViewer>
    </DockPanel>
</Window>
